{
  "name": "neurocore-mainframe",
  "version": "1.1.0",
  "description": "A cinematic full-stack mainframe interface with a separated Vite frontend and Rust backend.",
  "type": "module",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "cargo run --manifest-path backend/Cargo.toml",
    "build": "cargo build --manifest-path backend/Cargo.toml --release && npm --prefix frontend run build",
    "start": "cargo run --manifest-path backend/Cargo.toml --release",
    "preview": "npm run build && npm start",
    "test:api": "node scripts/api-tests.mjs",
    "screenshots": "node scripts/screenshots.mjs",
    "test:visual": "node scripts/visual-regression.mjs",
    "test:visual:update": "node scripts/visual-regression.mjs --update"
  },
  "keywords": [
    "vite",
    "mainframe",
    "hud",
    "terminal",
    "cyberpunk",
    "full-stack",
    "rust"
  ],
  "author": "NeuroCore Systems",
  "license": "Apache-2.0",
  "devDependencies": {}
}
